{
  "name": "vancouver-public-trees",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test --project=chromium",
    "test:browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js --project=chromium",
    "test:visual": "playwright test tests/e2e/visual.spec.js --project=chromium",
    "test:offline": "playwright test tests/e2e/offline.spec.js --project=chromium",
    "test:performance": "lhci autorun",
    "check": "tsc --project jsconfig.json",
    "city:import": "node scripts/city/import.js",
    "city:build": "node scripts/city/build-pack.js",
    "city:validate": "node scripts/city/validate.js",
    "check:bundle": "node scripts/check-bundle-budget.js"
  },
  "dependencies": {
    "maplibre-gl": "^4.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.61.1",
    "jsdom": "^24.0.0",
    "typescript": "^7.0.2",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
