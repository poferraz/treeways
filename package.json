{
  "name": "treeways",
  "version": "1.0.0",
  "description": "Neighbourhood discovery trails through Vancouver's public trees.",
  "type": "module",
  "license": "MIT",
  "author": "Paulo Ferraz",
  "repository": {
    "type": "git",
    "url": "https://github.com/poferraz/treeways.git"
  },
  "keywords": [
    "trees",
    "urban-canopy",
    "maplibre",
    "field-guide",
    "vancouver"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/inject-sw-version.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test --project=chromium",
    "test:browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js --project=chromium",
    "test:visual": "playwright test tests/e2e/visual.spec.js --project=chromium",
    "test:offline": "playwright test tests/e2e/offline.spec.js --project=chromium",
    "test:performance": "lhci autorun",
    "check": "tsc --project jsconfig.json",
    "city:import": "node scripts/city/import.js",
    "city:refresh": "node scripts/city/refresh.js",
    "city:refresh:full": "node scripts/city/refresh.js vancouver --full",
    "city:build": "node scripts/city/build-pack.js",
    "city:highlights": "node scripts/city/build-highlights.js",
    "city:pilots": "node scripts/city/build-pilots.js",
    "city:route-pilots": "node --env-file=.env.local scripts/city/route-pilots.js && node scripts/city/build-review-tool.js",
    "city:review-tool": "node scripts/city/build-review-tool.js",
    "city:validate": "node scripts/city/validate.js",
    "city:benchmark": "node scripts/city/benchmark-backends.js",
    "city:verify": "node scripts/verify-city-determinism.js",
    "check:bundle": "node scripts/check-bundle-budget.js"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@mapbox/vector-tile": "^1.3.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "jsdom": "^24.1.3",
    "geojson-vt": "^4.0.3",
    "pbf": "^3.3.0",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7",
    "vt-pbf": "^3.1.3"
  },
  "overrides": {
    "@lhci/cli": {
      "inquirer": "^8.2.7",
      "tmp": "^0.2.6",
      "uuid": "^11.1.1"
    }
  }
}
