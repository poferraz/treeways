{
  "name": "urban-canopy-engine",
  "version": "1.0.0",
  "description": "A map-first field guide for urban trees.",
  "type": "module",
  "license": "MIT",
  "author": "Urban Canopy Engine contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/poferraz/urban-canopy-engine.git"
  },
  "keywords": [
    "trees",
    "urban-canopy",
    "maplibre",
    "field-guide",
    "vancouver"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/inject-sw-version.js",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:e2e": "playwright test --project=chromium",
    "test:browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.js --project=chromium",
    "test:visual": "playwright test tests/e2e/visual.spec.js --project=chromium",
    "test:offline": "playwright test tests/e2e/offline.spec.js --project=chromium",
    "test:performance": "lhci autorun",
    "check": "tsc --project jsconfig.json",
    "city:import": "node scripts/city/import.js",
    "city:build": "node scripts/city/build-pack.js",
    "city:validate": "node scripts/city/validate.js",
    "check:bundle": "node scripts/check-bundle-budget.js"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "jsdom": "^24.1.3",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "@lhci/cli": {
      "inquirer": "^8.2.7",
      "tmp": "^0.2.6",
      "uuid": "^11.1.1"
    }
  }
}
